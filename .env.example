# Rooted Legacy environment placeholders.
# Copy to .env.local and fill as features are added. None are needed for v1.

# --- Future: database (Postgres / Neon) ---
# DATABASE_URL=

# --- Future: auth (Auth.js / NextAuth) ---
# AUTH_SECRET=
# AUTH_URL=

# --- Future: payments (Stripe) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Future: transactional email (Resend) ---
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=

# --- Weather ---
# Provider: "open-meteo" (no key, default) or "openweather" (needs key below).
# If unset, "openweather" is used when OPENWEATHER_API_KEY is present, otherwise "open-meteo".
# WEATHER_PROVIDER=open-meteo
#
# OpenWeather key — get one free at https://openweathermap.org/api.
# New keys take up to 2 hours to activate after signup.
OPENWEATHER_API_KEY=
#
# Defaults to 865 N German Church Rd, Indianapolis, IN. Override if needed.
# WEATHER_LAT=39.7745
# WEATHER_LON=-86.0103
# WEATHER_UNITS=imperial

# --- Future: headless CMS (Sanity / Payload) ---
# SANITY_PROJECT_ID=
# SANITY_DATASET=
# SANITY_READ_TOKEN=
