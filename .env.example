# Rooted Legacy — environment variables.
# Copy to .env.local for dev; configure the same vars in Vercel for prod.
# See docs/SETUP.md for provisioning instructions.

# --- Weather (already wired) ---
# Free key at https://openweathermap.org/api.
OPENWEATHER_API_KEY=
# Override coordinates if you want a different read point.
# WEATHER_LAT=39.7745
# WEATHER_LON=-86.0103
# WEATHER_UNITS=imperial

# --- Supabase (Phase 1 MVP) ---
# Create a project at https://supabase.com — copy values from Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # server-only; never expose to the client

# --- Resend (Phase 1 MVP) ---
# Sign up at https://resend.com. Use the default onboarding@resend.dev sender
# while developing; verify a domain before production.
RESEND_API_KEY=
# Optional: override the From header. Defaults to "Rooted Legacy <onboarding@resend.dev>".
# RESEND_FROM="Rooted Legacy <hello@rootedlegacy.org>"
# Where contact-form messages + vendor application notifications are sent.
CONTACT_TO_EMAIL=

# --- Admin role allowlist (Phase 1 MVP) ---
# Comma-separated emails that get the `admin` role at sign-in.
ADMIN_EMAIL_ALLOWLIST=

# --- Google Sheets produce inventory (Phase 1 MVP) ---
# Create a Google Cloud service account, enable Sheets API, share the sheet
# with the service account's email as Viewer.
# Paste the FULL JSON key here, or base64-encode it first (recommended).
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# --- Stripe (Phase 2 — uncomment when ready) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
